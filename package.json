{
  "name": "backend",
  "version": "0.0.1",
  "description": "",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "tsc",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "node dist/main",
    "start:dev": "ts-node src/main.ts",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "cleanup": "ts-node src/scripts/cleanup.ts",
    "seed": "ts-node src/scripts/seed.ts",
    "test:dlq": "ts-node src/scripts/test-dlq.ts",
    "test:kill-switch": "ts-node src/scripts/test-kill-switch.ts",
    "test:local-worker": "ts-node src/scripts/test-local-worker.ts",
    "verify:cloud": "ts-node src/scripts/verify-cloud-processing.ts",
    "verify:sagemaker": "ts-node src/scripts/verify-sagemaker.ts",
    "bundle": "esbuild dist/serverless.js --bundle --platform=node --target=node20 --outfile=dist/serverless-bundle.js --external:\"@aws-sdk/*\" --external:\"aws-sdk\" && esbuild dist/worker.js --bundle --platform=node --target=node20 --outfile=dist/worker-bundle.js --external:\"@aws-sdk/*\" --external:\"aws-sdk\" && esbuild dist/kill-switch.js --bundle --platform=node --target=node20 --outfile=dist/kill-switch-bundle.js --external:\"@aws-sdk/*\" --external:\"aws-sdk\" && esbuild dist/audit-consumer.js --bundle --platform=node --target=node20 --outfile=dist/audit-consumer-bundle.js --external:\"@aws-sdk/*\" --external:\"aws-sdk\""
  },
  "dependencies": {
    "@ai-sdk/groq": "^3.0.39",
    "@aws-sdk/client-api-gateway": "^3.1050.0",
    "@aws-sdk/client-cloudformation": "^3.1062.0",
    "@aws-sdk/client-dynamodb": "^3.1045.0",
    "@aws-sdk/client-firehose": "^3.1045.0",
    "@aws-sdk/client-lambda": "^3.1063.0",
    "@aws-sdk/client-s3": "^3.1045.0",
    "@aws-sdk/client-sagemaker-runtime": "^3.1063.0",
    "@aws-sdk/client-sqs": "^3.1052.0",
    "@aws-sdk/lib-dynamodb": "^3.1045.0",
    "@hono/node-server": "^1.13.8",
    "@mastra/core": "^1.32.1",
    "@mastra/engine": "^0.1.0-alpha.84",
    "ai": "^6.0.177",
    "aws-lambda": "^1.0.7",
    "dotenv": "^17.4.2",
    "electrodb": "^3.9.1",
    "hono": "^4.6.12",
    "uuid": "^14.0.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@eslint/js": "^9.18.0",
    "@types/aws-lambda": "^8.10.161",
    "@types/jest": "^30.0.0",
    "@types/node": "^24.0.0",
    "@types/supertest": "^7.0.0",
    "@types/uuid": "^10.0.0",
    "esbuild": "^0.28.0",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-prettier": "^5.2.2",
    "globals": "^17.0.0",
    "jest": "^30.0.0",
    "prettier": "^3.4.2",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  }
}
