{
	"Version": "2012-10-17",
	"Statement": [
		{
			"Sid": "AllowDataOperations",
			"Effect": "Allow",
			"Action": [
				"s3:GetObject",
				"s3:PutObject",
				"s3:DeleteObject",
				"dynamodb:GetItem",
				"dynamodb:PutItem",
				"dynamodb:UpdateItem",
				"dynamodb:DeleteItem",
				"dynamodb:Scan",
				"dynamodb:Query",
				"dynamodb:BatchWriteItem"
			],
			"Resource": [
				"arn:aws:s3:::ehr-demo-docs-bucket/*",
				"arn:aws:s3:::ehr-annotation-frontend-*/*",
				"arn:aws:dynamodb:ap-south-1:<AWS_ACCOUNT_ID>:table/ehr-table",
				"arn:aws:dynamodb:ap-south-1:<AWS_ACCOUNT_ID>:table/ehr-table/index/*"
			]
		},
		{
			"Sid": "AllowSageMakerInvocations",
			"Effect": "Allow",
			"Action": [
				"sagemaker:InvokeEndpoint"
			],
			"Resource": [
				"arn:aws:sagemaker:ap-south-1:<AWS_ACCOUNT_ID>:endpoint/gliner-relex-endpoint"
			]
		},
		{
			"Sid": "AllowListAndDescribeOnDataResources",
			"Effect": "Allow",
			"Action": [
				"s3:ListBucket",
				"dynamodb:DescribeTable"
			],
			"Resource": [
				"arn:aws:s3:::ehr-demo-docs-bucket",
				"arn:aws:s3:::ehr-annotation-frontend-*",
				"arn:aws:dynamodb:ap-south-1:<AWS_ACCOUNT_ID>:table/ehr-table"
			]
		},
		{
			"Sid": "AllowInfraReadAndDescribeOnly",
			"Effect": "Allow",
			"Action": [
				"cloudformation:DescribeStacks",
				"cloudformation:DescribeStackResources",
				"cloudformation:GetTemplate",
				"lambda:GetFunction",
				"lambda:GetFunctionConfiguration",
				"lambda:ListFunctions",
				"apigateway:GET",
				"sqs:GetQueueAttributes",
				"sqs:GetQueueUrl",
				"sns:GetTopicAttributes",
				"events:DescribeRule",
				"cloudfront:GetDistribution",
				"cloudfront:ListDistributions",
				"iam:GetRole",
				"iam:GetRolePolicy",
				"cloudwatch:DescribeAlarms",
				"logs:DescribeLogGroups",
				"logs:DescribeLogStreams",
				"logs:GetLogEvents"
			],
			"Resource": "*"
		},
		{
			"Sid": "StrictDenyInfraWriteAndDestruction",
			"Effect": "Deny",
			"Action": [
				"cloudformation:CreateStack",
				"cloudformation:DeleteStack",
				"cloudformation:UpdateStack",
				"s3:CreateBucket",
				"s3:DeleteBucket",
				"s3:PutBucket*",
				"dynamodb:CreateTable",
				"dynamodb:DeleteTable",
				"dynamodb:UpdateTable",
				"lambda:CreateFunction",
				"lambda:DeleteFunction",
				"lambda:UpdateFunctionCode",
				"lambda:UpdateFunctionConfiguration",
				"apigateway:POST",
				"apigateway:PUT",
				"apigateway:PATCH",
				"apigateway:DELETE",
				"sqs:CreateQueue",
				"sqs:DeleteQueue",
				"sns:CreateTopic",
				"sns:DeleteTopic",
				"events:PutRule",
				"events:DeleteRule",
				"cloudfront:CreateDistribution",
				"cloudfront:UpdateDistribution",
				"cloudfront:DeleteDistribution",
				"iam:CreateRole",
				"iam:DeleteRole",
				"iam:PutRolePolicy",
				"iam:DeleteRolePolicy",
				"iam:AttachRolePolicy",
				"iam:DetachRolePolicy"
			],
			"Resource": "*"
		}
	]
}
